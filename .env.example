# ─── GitVibe configuration ───────────────────────────────────────────────
# Copy to .env and fill in what you need. Everything has a sane default.
# Nothing here is required to start the app; providers are optional.

# Database (SQLite by default — file is created automatically)
DATABASE_URL="file:./data/gitvibe.db"

# ─── Git provider tokens (optional, raise rate limits / private repos) ─────
# Personal access tokens. Leave blank for public repos at anonymous limits.
GITHUB_TOKEN=""
GITLAB_TOKEN=""
BITBUCKET_TOKEN=""
# For self-hosted Gitea, users pass the host + token from the UI per-request.

# ─── LLM providers (optional — needed only for AI-summarised Deep/Ultra) ───
# Quick & Standard modes work with ZERO LLM keys (pure static analysis).
# Configure any subset; the UI lets the user pick which to use.

# Ollama (local, free) — point at your running daemon
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5-coder:7b"

# Groq
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# OpenRouter
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# Anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# OpenAI (or any OpenAI-compatible endpoint)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# ─── App behaviour ─────────────────────────────────────────────────────────
# Default LLM provider when none chosen in UI: ollama | groq | openrouter | anthropic | openai
DEFAULT_LLM_PROVIDER="ollama"
# Simple in-memory rate limit: requests per window per IP
RATE_LIMIT_MAX="30"
RATE_LIMIT_WINDOW_MS="60000"
# Max files GitVibe will read content for in Deep/Ultra modes
MAX_DEEP_FILES="40"
